    {
      "name": "Content CRUD (Dynamic)",
      "description": "Folder containing dynamic content endpoints. Use parameter `:contentType` in URLs. Valid types:\n- beranda-content\n- profil-content\n- program-pendidikan-content\n- kelembagaan-internal-content\n- widyaiswara-content\n- publikasi-content\n- berita-informasi-content\n- galeri-unduhan-content\n- kontak-content\n- sarana-prasarana-content",
      "item": [
        {
          "name": "List Content Records (Public)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/:contentType?search=&category=&status=Published&page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                ":contentType"
              ],
              "query": [
                {
                  "key": "search",
                  "value": "",
                  "description": "Filter by searching title/author"
                },
                {
                  "key": "category",
                  "value": "",
                  "description": "Filter by category name"
                },
                {
                  "key": "status",
                  "value": "Published",
                  "description": "Filter by status (Published, Draft)"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default 1)"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Records per page (default 10)"
                }
              ]
            },
            "description": "Publicly fetch content records from specific table. Swap ':contentType' with valid content types (e.g. beranda-content, profil-content)."
          },
          "response": []
        },
